      "note": "Extractor nuance: -que enclitic on Populusque — formal additive conjunction",
      "pipeline": "extractor",
      "assert_types_present": ["nuance"],
      "assert_types_absent": [],
      "assert_nuance_type": "enclitic_que",
      "assert_nuance_types_absent": [],
      "assert_canonical_contains": null,
      "confidence_ge": 0.75,
      "lesson_data_required_keys": {
        "nuance": ["nuance_type", "explanation", "register", "learner_level", "source", "host_word"]
      },
      "no_raw_uuids": true
    },
    {
      "id": "la_etymology_vocab_01",
      "category": "etymology_vocab",

{
  "language": "la",
  "plugin_module": "backend.plugins.latin",
  "plugin_class": "LatinPlugin",
  "nuance_extractor_module": "backend.nuance.la",
  "nuance_extractor_class": "LatinNuanceExtractor",
  "tokenizer": "words",
  "capability_assertions": {
    "idioms": ["none"],
    "grammar_nuance": ["none"]
  },
  "capability_gaps": {
    "grammar_nuance": "Plugin declares 'none' but extractor provides discourse_particle and enclitic_que nuances"
  },
  "cases": [
    {
      "id": "la_extractor_nuance_discourse_particle_autem",
      "category": "grammar_nuance",
      "text": "Caesar autem in Gallia erat.",
      "note": "Extractor nuance: 'autem' — adversative/continuative discourse particle (postpositive)",
      "pipeline": "extractor",
      "assert_types_present": ["nuance"],
      "assert_types_absent": [],
      "assert_nuance_type": "discourse_particle",
      "assert_nuance_types_absent": [],
      "assert_canonical_contains": null,
      "confidence_ge": 0.8,
      "lesson_data_required_keys": {
        "nuance": ["nuance_type", "explanation", "register", "learner_level", "source", "particle"]
      },
      "no_raw_uuids": true
    },
    {
      "id": "la_extractor_nuance_discourse_particle_igitur",
      "category": "grammar_nuance",
      "text": "Cogito, ergo sum.",
      "note": "Extractor nuance: 'ergo' — inferential discourse particle ('therefore')",
      "pipeline": "extractor",
      "assert_types_present": ["nuance"],
      "assert_types_absent": [],
      "assert_nuance_type": "discourse_particle",
      "assert_nuance_types_absent": [],
      "assert_canonical_contains": null,
      "confidence_ge": 0.8,
      "lesson_data_required_keys": {
        "nuance": ["nuance_type", "explanation", "register", "learner_level", "source", "particle"]
      },
      "no_raw_uuids": true
    },
    {
      "id": "la_extractor_nuance_enclitic_que",

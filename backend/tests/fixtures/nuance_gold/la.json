      "assert_nuance_types_absent": [],
      "assert_canonical_contains": "persona",
      "confidence_ge": null,
      "lesson_data_required_keys": {},
      "no_raw_uuids": true
    },
    {
      "id": "la_false_positive_01",
      "category": "false_positive",
      "text": "Puella librum legit.",
      "note": "Plain simple sentence — no discourse particles, no -que enclitic",
      "pipeline": "extractor",
      "assert_types_present": [],
      "assert_types_absent": [],

{
  "language": "ja",
  "plugin_module": "backend.plugins.japanese",
  "plugin_class": "JapanesePlugin",
  "nuance_extractor_module": "backend.nuance.ja",
  "nuance_extractor_class": "JapaneseNuanceExtractor",
  "tokenizer": "spacy",
  "capability_assertions": {
    "idioms": ["none", "stub"],
    "grammar_nuance": ["stub", "partial"],
    "formality_register": ["none", "stub"]
  },
  "capability_gaps": {
    "idioms": "Plugin declares 'none' but extractor provides yojijukugo (4-char idiom compounds)",
    "formality_register": "Plugin declares 'none' but extractor provides keigo (sonkeigo/kenjogo/teineigo) nuances"
  },
  "cases": [
    {
      "id": "ja_extractor_nuance_particle_wa",
      "category": "grammar_nuance",
      "text": "猫は魚を食べます。",
      "note": "Extractor nuance: は (wa) topic marker — marks topic, implies contrast",
      "pipeline": "extractor",
      "assert_types_present": ["nuance"],
      "assert_types_absent": [],
      "assert_nuance_type": "particle",
      "assert_nuance_types_absent": [],
      "assert_canonical_contains": null,
      "confidence_ge": 0.85,
      "lesson_data_required_keys": {
        "nuance": ["nuance_type", "explanation", "register", "learner_level", "source"]
      },
      "no_raw_uuids": true
    },
    {
      "id": "ja_extractor_nuance_particle_ga",

{
  "language": "ar",
  "plugin_module": "backend.plugins.arabic",
  "plugin_class": "ArabicPlugin",
  "nuance_extractor_module": "backend.nuance.ar",
  "nuance_extractor_class": "ArabicNuanceExtractor",
  "tokenizer": "words",
  "capability_assertions": {
    "idioms": ["none"],
    "grammar_nuance": ["none"]
  },
  "capability_gaps": {
    "grammar_nuance": "Plugin declares 'none' but extractor provides definite_article and negation nuances"

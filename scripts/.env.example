# ============================================================================
# extend_cultural_catalogue.py — provider configuration
# ============================================================================
#
# QUICK START
# -----------
# 1. Copy this file:
#       cp scripts/.env.example scripts/.env
#
# 2. Fill in CULTURAL_CATALOGUE_API_KEY and optionally BASE_URL + MODEL.
#
# 3. Run from the project root (not from scripts/):
#
#    Estimate cost before spending anything:
#       python scripts/extend_cultural_catalogue.py --estimate-cost --target 500
#       python scripts/extend_cultural_catalogue.py --estimate-cost --target 500 --with-i18n --all-languages
#
#    Generate draft for Spanish (human reviews, then promotes manually):
#       python scripts/extend_cultural_catalogue.py --language es --target 150
#
#    Generate + AI review + auto-promote in one shot:
#       python scripts/extend_cultural_catalogue.py --language es --target 150 \
#           --auto-review --auto-promote --reviewed-by "pipeline-v1"
#
#    Full pipeline with i18n translations:
#       python scripts/extend_cultural_catalogue.py --language fr --target 500 \
#           --with-i18n --auto-review --auto-promote
#
#    Resume an interrupted run (picks up from .progress.json):
#       python scripts/extend_cultural_catalogue.py --language de --target 500 --resume
#
#    Use a different model for review (cheaper generate, better review):
#       python scripts/extend_cultural_catalogue.py --language zh --target 150 \
#           --model deepseek-chat --review-model gpt-4o-mini --auto-review
#
# 4. After manual draft generation, promote via existing workflow:
#       # Create allowlist: one canonical_reference per line
#       python scripts/promote_cultural_drafts.py \
#           --draft data/cultural_drafts/es_cultural_references_v1.generated.yaml \
#           --allowlist data/cultural_drafts/es_catalogue_batch_001.txt \
#           --seed data/cultural_references_seed.yaml \
#           --reviewed-by <yourname> --reviewed-at $(date +%F)
#       # Rebuild runtime files:
#       python scripts/build_cultural_catalog.py --write
#       # Update hardcoded counts in backend/tests/test_cultural_catalog.py
#
# ============================================================================
# PIPELINE PHASES
# ============================================================================
#
#   Phase 1  discover   LLM generates candidate canonical references (batched)
#   Phase 2  enrich     LLM adds source, surface patterns, explanation, metadata
#   Phase 3  i18n       LLM translates short_explanation into 11 UI languages
#                       (enabled with --with-i18n; skipped by default)
#   Phase 4  review     Second LLM call fact-checks each entry (--auto-review)
#                       Verdicts: approve / flag / reject
#                       Flagged  -> <output>.flagged.yaml  (check manually)
#                       Rejected -> <output>.rejected.json (with reasons)
#   Phase 5  promote    Approved entries added to seed (--auto-promote)
#                       Calls promote_cultural_drafts.py automatically
#
# ============================================================================
# PROVIDER SETUP
# ============================================================================
#
# The script uses the openai Python SDK with a configurable base URL, so it
# works with any OpenAI-compatible API endpoint.
#
# ── Option A: OpenAI (default) ───────────────────────────────────────────────
#
# API key from https://platform.openai.com/api-keys
CULTURAL_CATALOGUE_API_KEY=sk-proj-...
# CULTURAL_CATALOGUE_BASE_URL is optional for OpenAI (defaults correctly)
CULTURAL_CATALOGUE_MODEL=gpt-4o-mini
CULTURAL_CATALOGUE_REVIEW_MODEL=gpt-4o-mini
#
# Recommended model ladder:
#   gpt-4.1-nano    cheapest; fine for European languages
#   gpt-4o-mini     recommended default; good balance
#   gpt-4.1-mini    better source attribution
#   gpt-4.1         best for classical (Latin, Ancient Greek, Sanskrit)
#
# ── Option B: DeepSeek (cheapest non-local, best for CJK / Arabic) ──────────
#
# API key from https://platform.deepseek.com/api_keys
# CULTURAL_CATALOGUE_API_KEY=sk-...
# CULTURAL_CATALOGUE_BASE_URL=https://api.deepseek.com/v1
# CULTURAL_CATALOGUE_MODEL=deepseek-chat
# CULTURAL_CATALOGUE_REVIEW_MODEL=deepseek-chat
#
# Cost ~$0.12/language for 500 entries + review (vs $0.22 for gpt-4o-mini).
# Especially strong on zh, ja, ko, ar. Use deepseek-reasoner for review
# if you want slower but more rigorous fact-checking.
#
# ── Option C: Gemini via OpenAI-compatible endpoint ──────────────────────────
#
# API key from https://aistudio.google.com/apikey
# CULTURAL_CATALOGUE_API_KEY=AIza...
# CULTURAL_CATALOGUE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CULTURAL_CATALOGUE_MODEL=gemini-2.0-flash
# CULTURAL_CATALOGUE_REVIEW_MODEL=gemini-2.0-flash
#
# gemini-2.0-flash-lite is near-free (free tier available); adequate for
# discovery phase but weaker on source attribution.
#
# ── Option D: Mistral ────────────────────────────────────────────────────────
#
# API key from https://console.mistral.ai/api-keys
# CULTURAL_CATALOGUE_API_KEY=...
# CULTURAL_CATALOGUE_BASE_URL=https://api.mistral.ai/v1
# CULTURAL_CATALOGUE_MODEL=mistral-small-latest
# CULTURAL_CATALOGUE_REVIEW_MODEL=mistral-small-latest
#
# Good coverage for French, Italian, Spanish, Portuguese.
#
# ── Option E: Local Ollama (free, no internet required) ──────────────────────
#
# Install Ollama from https://ollama.ai and pull a model:
#   ollama pull llama3.3:70b        # ~40 GB download
#   ollama pull llama3.1:8b         # ~5 GB; weaker but runs on most hardware
#
# CULTURAL_CATALOGUE_API_KEY=ollama
# CULTURAL_CATALOGUE_BASE_URL=http://localhost:11434/v1
# CULTURAL_CATALOGUE_MODEL=llama3.3:70b
# CULTURAL_CATALOGUE_REVIEW_MODEL=llama3.3:70b
#
# Note: Ollama may not support response_format=json_object for all models;
# the script auto-retries without it if the API rejects the request.
#
# ── Option F: LM Studio ──────────────────────────────────────────────────────
#
# Load a model in LM Studio, enable Local Server, then:
# CULTURAL_CATALOGUE_API_KEY=lm-studio
# CULTURAL_CATALOGUE_BASE_URL=http://localhost:1234/v1
# CULTURAL_CATALOGUE_MODEL=<model-name-from-lm-studio>
#
# ── Option G: Mixed provider (generate cheap, review better) ─────────────────
#
# Use CLI flags to override per-phase model:
#   python scripts/extend_cultural_catalogue.py \
#       --language ar --target 150 \
#       --model deepseek-chat \
#       --review-model gpt-4o-mini \
#       --auto-review
#
# The CULTURAL_CATALOGUE_* env vars set the default; --model and
# --review-model override them for that run.
#
# ============================================================================
# ALL ENVIRONMENT VARIABLES
# ============================================================================
#
# CULTURAL_CATALOGUE_API_KEY      API key. Fallback: OPENAI_API_KEY.
# CULTURAL_CATALOGUE_BASE_URL     API base URL. Omit for OpenAI default.
# CULTURAL_CATALOGUE_MODEL        Generation model. Default: gpt-4o-mini.
# CULTURAL_CATALOGUE_REVIEW_MODEL Review model. Default: same as MODEL.
#
# ============================================================================
# REQUIREMENTS
# ============================================================================
#
#   pip install openai python-dotenv pyyaml
#
# ============================================================================
# OUTPUT FILES
# ============================================================================
#
#   <lang>_cultural_references_v1.generated.yaml   draft entries
#   <lang>_cultural_references_v1.flagged.yaml     flagged (AI review)
#   <lang>_cultural_references_v1.rejected.json    rejected (AI review)
#   <lang>_cultural_references_v1.progress.json    resume state (deleted on completion)
#
# ============================================================================

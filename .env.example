# Copy this file to .env and fill in your values before running anything.
#
# Docker Compose — use the service names as hostnames (postgres, redis).
# Plain local dev — replace with localhost.
#
#   cp .env.example .env

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Mnemosyne

# Set to false in production.
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# Connection string for the FastAPI app (asyncpg driver).
# Hostname must match the Compose service name when running via Docker.
DATABASE_URL=postgresql+asyncpg://mnemosyne:changeme@postgres:5432/mnemosyne

# These three are consumed directly by the postgres service in docker-compose.yml.
POSTGRES_DB=mnemosyne
POSTGRES_USER=mnemosyne
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins.  Never use ["*"] in production.
CORS_ORIGINS=["http://localhost:8000"]

# ── JWT authentication ────────────────────────────────────────────────────────
# REQUIRED in production: replace with a long random secret.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# ── Rate limiting ─────────────────────────────────────────────────────────────
# slowapi / limits syntax: "N/period"  (second | minute | hour | day)
# Multiple limits: "5/second;100/hour"
RATE_LIMIT_PARSE=20/minute

# Storage backend for rate-limit counters.
# Default (memory://) is per-process — fine for single-worker deployments.
# Multi-worker: set to a Redis URL so all workers share the same counter.
# Use a separate DB index from the parse cache (which uses index 0 by default).
# SLOWAPI_STORAGE_URI=redis://redis:6379/1

# ── Input guard ───────────────────────────────────────────────────────────────
# Maximum characters accepted by /parse and /ingest.  Texts above this size
# return 413 before any NLP work is done.
MAX_PARSE_CHARS=10000

# ── Dictionary enrichment ─────────────────────────────────────────────────────
# When true, vocabulary objects extracted during /parse are enriched with
# English glosses from the public Wiktionary REST API in the background.
# Disabled by default to avoid external network calls in development and CI.
# ENABLE_DICTIONARY_LOOKUP=false

# ── Error monitoring ──────────────────────────────────────────────────────────
# Leave SENTRY_DSN unset (or empty) to disable Sentry.
# Set to your project DSN to enable: https://key@sentry.io/project_id
SENTRY_DSN=
# Defaults to "development" when DEBUG=true, "production" when DEBUG=false.
# Set explicitly to "staging" etc. if needed.
SENTRY_ENVIRONMENT=

# ── Plugins ───────────────────────────────────────────────────────────────────
PLUGIN_PACKAGE=backend.plugins

# Restrict which language plugins are loaded at startup.
# Comma-separated BCP-47 codes, e.g. ENABLED_LANGUAGES=es,fr
# When unset (the default), all plugins in PLUGIN_PACKAGE are loaded.
# Plugins outside this list are silently skipped — existing data for those
# languages in the database is preserved but not accessible via the API.
# ENABLED_LANGUAGES=
